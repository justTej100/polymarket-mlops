# =============================================================================
# polymarket-mlops — copy to .env and edit as needed
# First run: make run   (creates .venv, installs deps, copies this file to .env, starts everything)
# No API keys required for v1 paper mode (DRY_RUN=true, System B off).
# =============================================================================

# --- LLM (System B only — not used in v1) ---
# Google Gemini is free at https://aistudio.google.com
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
LLM_PROVIDER=google

# --- External data (System B only — not used in v1) ---
# Free tier at https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# --- Polymarket wallet (live trading only — leave empty while DRY_RUN=true) ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_ADDRESS=

# --- Infrastructure (defaults match docker-compose; start with: make up) ---
REDIS_URL=redis://localhost:6379/0
MLFLOW_TRACKING_URI=http://localhost:5000
SIGNAL_SERVICE_URL=http://localhost:8000

# --- Safety ---
# true = simulate orders only (recommended until you audit live behavior)
DRY_RUN=true

# --- Which systems run (supervisor reads these on make start) ---
RUN_SYSTEM_A=true
RUN_SYSTEM_B=false
RUN_SYSTEM_C=true

# --- System A strategy toggles (v1 implements strategies 2 and 9 only) ---
RUN_STRAT1=false
RUN_STRAT2=true
RUN_STRAT3=false
RUN_STRAT4=false
RUN_STRAT5=false
RUN_STRAT6=false
RUN_STRAT7=false
RUN_STRAT8=false
RUN_STRAT9=true

# autonomous = signal goes straight to API; reviewed = pass through System B first (future)
STRATEGY_A_DEFAULT_MODE=autonomous

# --- Feature pipeline ---
# When true, uses mock Polymarket order books (supervisor sets true automatically if DRY_RUN=true)
FEATURE_PIPELINE_MOCK=true

# --- Strategy 2 — 99c Sniper ---
STRAT2_MAX_TIME_REMAINING_SECONDS=60
STRAT2_MAX_ASK_PRICE=0.99
STRAT2_MIN_SPOT_DISTANCE_FROM_STRIKE=100
STRAT2_MAX_SHARES=1000
STRAT2_MAX_NOTIONAL_USD=100

# --- Strategy 9 — Dump-Hedge (always autonomous) ---
STRAT9_DUMP_PCT_THRESHOLD=0.003
STRAT9_DUMP_WINDOW_SECONDS=10
STRAT9_UP_TOKEN_MAX_ENTRY=0.15
STRAT9_HEDGE_MAX_COMBINED_COST=0.98
STRAT9_FIRST_LEG_SHARES=200
STRAT9_TAKE_PROFIT_1=0.25
STRAT9_TAKE_PROFIT_2=0.40
STRAT9_SINGLE_LEG_STOP_LOSS=0.05
STRAT9_MAX_NOTIONAL_HEDGED_USD=200
STRAT9_MAX_NOTIONAL_NAKED_USD=50
STRAT9_MODE=autonomous

# --- System B (stub in v1) ---
AGENT_RUN_INTERVAL_MINUTES=60

# --- System C — copytrade top wallets ---
COPY_TARGET_COUNT=10
COPY_SIZE_MULTIPLIER=0.1
COPY_MAX_ORDER_USD=5
COPY_POLL_INTERVAL_MS=15000

# --- Meta-learner ---
META_COLD_START_WEIGHTS=0.33,0.33,0.33
META_MIN_OUTCOMES_TO_LEARN=50

# --- Session risk (paper trader halts new entries if drawdown exceeded) ---
SESSION_BUDGET_USD=1000
SESSION_DRAWDOWN_KILL_PCT=0.10
