# ---------------------------------------------------------------------------
# Copy this file to .env and you're done -- every market data feed the app
# uses (Polymarket Gamma, Polymarket CLOB, Polymarket real-time data socket,
# Binance klines) is public and needs no API key.
# ---------------------------------------------------------------------------

# Local SQLite database used by Prisma (default -- works out of the box).
DATABASE_URL="file:./dev.db"

# Optional: Neon/Postgres connection string. Leave empty to stay on SQLite;
# set it to your Neon URL and the app switches Prisma clients automatically.
# Get one at https://neon.tech -> your project -> Connection string.
NEON_DATABASE_URL=""
