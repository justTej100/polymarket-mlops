# ---------------------------------------------------------------------------
# Copy this file to .env and you're done -- every market data feed the app
# uses (Polymarket Gamma, Polymarket CLOB, Polymarket real-time data socket,
# Binance klines) is public and needs no API key.
# ---------------------------------------------------------------------------

# Local SQLite database used by Prisma (default -- works out of the box).
DATABASE_URL="file:./dev.db"

# Optional: Neon/Postgres connection string. Leave empty to stay on SQLite;
# set it to your Neon URL and the app switches Prisma clients automatically.
# Get one at https://neon.tech -> your project -> Connection string.
NEON_DATABASE_URL=""

# ---------------------------------------------------------------------------
# OPTIONAL: copy trading with REAL MONEY.
# Leave these empty and the app runs in paper-trading mode only.
#
# Filling these in lets the dashboard's Copy Trading panel mirror one
# strategy's trades onto your real Polymarket account. Orders are only ever
# placed after you also switch copying ON in the dashboard (or set
# COPY_TRADING_ENABLED=true). Start with a tiny stake.
# ---------------------------------------------------------------------------

# Exported from Polymarket: profile -> Settings -> Export private key.
# (If you log in with your own browser wallet, use that wallet's key instead.)
POLYMARKET_PRIVATE_KEY=""

# Your Polymarket deposit/profile address -- the one that holds your USDC.
POLYMARKET_FUNDER_ADDRESS=""

# How your Polymarket account was created:
#   1 = email / Magic login (most accounts -- default)
#   2 = browser wallet (MetaMask etc.)
#   0 = trading directly from a raw wallet (no Polymarket proxy)
POLYMARKET_SIGNATURE_TYPE="1"

# Which strategy to copy and how many dollars to spend per entry.
# Both can also be changed live from the dashboard.
COPY_STRATEGY_ID="momentum-confluence"
COPY_STAKE_USD="5"

# Master switch. Keep false until you've watched the paper trades for a while.
COPY_TRADING_ENABLED="false"
