# =============================================================================
# polymarket-mlops — copy to .env and edit as needed
# First run: make run   (creates .venv, installs deps, copies this file to .env, starts everything)
# No API keys required for v1 paper mode (DRY_RUN=true, System B off).
# =============================================================================

# --- LLM (System B only — not used in v1) ---
# Google Gemini is free at https://aistudio.google.com
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
LLM_PROVIDER=google

# --- External data (System B only — not used in v1) ---
# Free tier at https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# --- Polymarket wallet (live trading only — leave empty while DRY_RUN=true) ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_ADDRESS=

# --- Infrastructure (defaults match docker-compose; start with: make up) ---
REDIS_URL=redis://localhost:6379/0
MLFLOW_TRACKING_URI=http://localhost:5000
SIGNAL_SERVICE_URL=http://localhost:8000

# --- Safety ---
# true = simulate orders only (recommended until you audit live behavior)
DRY_RUN=true

# --- Which systems run (supervisor reads these on make start) ---
RUN_SYSTEM_A=true
RUN_SYSTEM_B=false
RUN_SYSTEM_C=true

# --- System A strategy toggles (all 9 implemented; enable individually) ---
RUN_STRAT1=false
RUN_STRAT2=true
RUN_STRAT3=false
RUN_STRAT4=false
RUN_STRAT5=false
RUN_STRAT6=false
RUN_STRAT7=false
RUN_STRAT8=false
RUN_STRAT9=true

# autonomous = signal goes straight to API; reviewed = pass through System B first (future)
STRATEGY_A_DEFAULT_MODE=autonomous

# --- Feature pipeline ---
# When true, uses mock Polymarket order books (supervisor sets true automatically if DRY_RUN=true)
FEATURE_PIPELINE_MOCK=true

# --- Strategy 1 — 1c Buy ---
STRAT1_BID_LEVELS=0.01,0.02,0.03
STRAT1_ENTRY_DELAY_SECONDS=45
STRAT1_SHARES_PER_ORDER=10
STRAT1_CANCEL_BEFORE_EXPIRY_SECONDS=30
STRAT1_MAX_NOTIONAL_USD=20

# --- Strategy 2 — 99c Sniper ---
STRAT2_MAX_TIME_REMAINING_SECONDS=60
STRAT2_MAX_ASK_PRICE=0.99
STRAT2_MIN_SPOT_DISTANCE_FROM_STRIKE=100
STRAT2_MAX_SHARES=1000
STRAT2_MAX_NOTIONAL_USD=100

STRAT2_MAX_NOTIONAL_USD=100

# --- Strategy 3 — Dual Reversion ---
STRAT3_MAX_ASK_EITHER_SIDE=0.48
STRAT3_MIN_ASK_EITHER_SIDE=0.30
STRAT3_MAX_COMBINED_COST=0.98
STRAT3_MIN_TIME_REMAINING_SECONDS=120
STRAT3_MAX_NOTIONAL_PER_SIDE_USD=100

# --- Strategy 4 — Pre-Order ---
STRAT4_CURRENT_MARKET_STABLE_MIN=0.35
STRAT4_CURRENT_MARKET_STABLE_MAX=0.65
STRAT4_PRE_ORDER_PRICE=0.45
STRAT4_ENTRY_WINDOW_SECONDS_BEFORE_CLOSE=120
STRAT4_SHARES_PER_SIDE=100
STRAT4_MAX_NOTIONAL_USD=100

# --- Strategy 5 — Cross-Market ---
STRAT5_LEAD_ASSET=BTC
STRAT5_LAG_ASSETS=ETH,SOL,XRP
STRAT5_MIN_LEAD_MOVE_PCT=0.0025
STRAT5_MAX_LAG_SECONDS=30
STRAT5_AGGRESSIVE_LIMIT_SLIPPAGE=0.03
STRAT5_MAX_NOTIONAL_PER_PAIR_USD=75

# --- Strategy 6 — Martingale / Anti-Martingale ---
STRAT6_MODE=auto
STRAT6_ENTRY_PRICE=0.45
STRAT6_ENTRY_RANGE=0.03
STRAT6_MARTINGALE_HARD_STOP=0.15
STRAT6_ANTI_CONFIRM_MOVE=0.07
STRAT6_REGIME_LOOKBACK_SECONDS=120
STRAT6_MAX_NOTIONAL_USD=150

# --- Strategy 7 — Fibonacci ---
STRAT7_SWING_OBSERVE_SECONDS=90
STRAT7_FIB_LEVELS=0.236,0.382,0.500,0.618
STRAT7_INVALIDATION_BUFFER=0.02
STRAT7_MIN_TIME_REMAINING_SECONDS=90
STRAT7_SIZE_LARGEST_LEVEL=100
STRAT7_SIZE_SCALE_FACTOR=0.75
STRAT7_MAX_NOTIONAL_USD=120

# --- Strategy 8 — MACD / RSI / VWAP ---
STRAT8_BAR_SECONDS=5
STRAT8_MACD_FAST=3
STRAT8_MACD_SLOW=8
STRAT8_MACD_SIGNAL=3
STRAT8_RSI_PERIOD=14
STRAT8_RSI_NEUTRAL_LOW=40
STRAT8_RSI_NEUTRAL_HIGH=65
STRAT8_RSI_OVERBOUGHT=75
STRAT8_VWAP_STRETCH_LIMIT=0.10
STRAT8_MIN_SCORE_TO_ENTER=4
STRAT8_MAX_NOTIONAL_USD=100

# --- Strategy 9 — Dump-Hedge (always autonomous) ---
STRAT9_DUMP_PCT_THRESHOLD=0.003
STRAT9_DUMP_WINDOW_SECONDS=10
STRAT9_UP_TOKEN_MAX_ENTRY=0.15
STRAT9_HEDGE_MAX_COMBINED_COST=0.98
STRAT9_FIRST_LEG_SHARES=200
STRAT9_TAKE_PROFIT_1=0.25
STRAT9_TAKE_PROFIT_2=0.40
STRAT9_SINGLE_LEG_STOP_LOSS=0.05
STRAT9_MAX_NOTIONAL_HEDGED_USD=200
STRAT9_MAX_NOTIONAL_NAKED_USD=50
STRAT9_MODE=autonomous

# --- System B (stub in v1) ---
AGENT_RUN_INTERVAL_MINUTES=60

# --- System C — copytrade top wallets ---
COPY_TARGET_COUNT=10
COPY_SIZE_MULTIPLIER=0.1
COPY_MAX_ORDER_USD=5
COPY_POLL_INTERVAL_MS=15000

# --- Meta-learner ---
META_COLD_START_WEIGHTS=0.33,0.33,0.33
META_MIN_OUTCOMES_TO_LEARN=50

# --- Session risk (paper trader halts new entries if drawdown exceeded) ---
SESSION_BUDGET_USD=1000
SESSION_DRAWDOWN_KILL_PCT=0.10
