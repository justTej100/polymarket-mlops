// Neon/Postgres Prisma schema.
// Use this when NEON_DATABASE_URL is present.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/neon-client"
}

datasource db {
  provider = "postgresql"
  url      = env("NEON_DATABASE_URL")
}

model Market {
  id          String   @id @default(cuid())
  conditionId String   @unique
  asset       String
  priceToBeat Float
  openTime    DateTime
  closeTime   DateTime
  resolved    Boolean  @default(false)
  outcome     String?
  signals     Signal[]

  @@index([openTime])
}

model Signal {
  id             String        @id @default(cuid())
  marketId       String
  market         Market        @relation(fields: [marketId], references: [id])
  strategyId     String
  direction      String
  confidence     Float?
  entryPrice     Float?
  entryCostUsd   Float?
  createdAt      DateTime      @default(now())
  won            Boolean?
  closedAt       DateTime?
  exitPrice      Float?
  realizedPnlUsd Float?
  exitReason     String?
  result         String?
  events         SignalEvent[]

  @@index([strategyId])
  @@index([marketId])
}

model SignalEvent {
  id             String   @id @default(cuid())
  signalId       String
  signal         Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  eventType      String
  price          Float?
  quantity       Float?
  realizedPnlUsd Float?   @default(0)
  note           String?
  createdAt      DateTime @default(now())

  @@index([signalId])
  @@index([eventType])
}

model BacktestRun {
  id         String   @id @default(cuid())
  startedAt  DateTime @default(now())
  rangeStart DateTime
  rangeEnd   DateTime
  results    String
}