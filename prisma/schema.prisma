// Neon Postgres via Prisma.
// Set DATABASE_URL in .env to your Neon connection string
// (Neon dashboard -> Connection Details -> "Pooled connection" string works fine here).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// One row per market window we've observed (a single 5-minute BTC Up/Down market).
model Market {
  id          String   @id @default(cuid())
  conditionId String   @unique // Polymarket condition id for this 5-min window
  asset       String   // "BTC" for now
  priceToBeat Float
  openTime    DateTime
  closeTime   DateTime
  resolved    Boolean  @default(false)
  outcome     String?  // "YES" | "NO" once resolved
  signals     Signal[]

  @@index([openTime])
}

// One row per strategy signal fired for a given market window (live mode).
model Signal {
  id           String   @id @default(cuid())
  marketId     String
  market       Market   @relation(fields: [marketId], references: [id])
  strategyId   String   // e.g. "lottery-ticket"
  direction    String   // "YES" | "NO" | "NEUTRAL"
  confidence   Float?
  entryPrice   Float?
  createdAt    DateTime @default(now())

  // Filled in once the market resolves, so we can compute win rate per strategy.
  won          Boolean?

  @@index([strategyId])
  @@index([marketId])
}

// One row per backtest run, so simulation results are comparable across runs.
model BacktestRun {
  id          String   @id @default(cuid())
  startedAt   DateTime @default(now())
  rangeStart  DateTime
  rangeEnd    DateTime
  results     Json     // { [strategyId]: { trades, wins, pnl, winRate } }
}
